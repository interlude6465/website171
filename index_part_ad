  function rgbToHex(rgb) {
    if (!rgb || rgb === '') return '';
    var m = rgb.match(/^#([0-9a-fA-F]{3,6})$/);
    if (m) return '#' + m[1];
    m = rgb.match(/rgb\((\d+),\s*(\d+),\s*(\d+)\)/);
    if (m) return '#' + [m[1], m[2], m[3]].map(function(x) { var h = parseInt(x).toString(16); return h.length === 1 ? '0' + h : h; }).join('');
    return rgb;
  }

